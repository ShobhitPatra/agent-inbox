{
  "name": "agent-inbox",
  "version": "0.0.0",
  "description": "kubectl for AI agents — a terminal approval inbox where autonomous agents queue actions and a human clears the queue (approve / edit / deny)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-inbox": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.tsx --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@assistant-ui/react-ink": "file:.vendor/assistant-ui-react-ink-0.0.31.tgz",
    "@assistant-ui/react-ink-markdown": "file:.vendor/assistant-ui-react-ink-markdown-0.0.30.tgz",
    "assistant-cloud": "^0.1.34",
    "ink": "^7",
    "react": "^19",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "esbuild": "^0.24",
    "ink-testing-library": "^4",
    "oxfmt": "^0.5",
    "oxlint": "^1",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}